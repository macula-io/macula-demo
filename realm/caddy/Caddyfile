{
	on_demand_tls {
		ask http://central:4001/api/v1/internal/check-domain
	}
}

# Auctions subdomain
auctions.macula.io {
	tls {
		dns linode {env.LINODE_DNS_API_TOKEN}
		key_type rsa2048
	}
	reverse_proxy central:4001
}

# Wildcard subdomain — relay health + franchise storefronts
# relay-*.macula.io /health and /status → relay container
# Everything else → central (franchise storefronts)
*.macula.io {
	tls {
		dns linode {env.LINODE_DNS_API_TOKEN}
		key_type rsa2048
	}

	@relay_status {
		header_regexp Host relay
		path /health /status
	}
	handle @relay_status {
		reverse_proxy relay:8080
	}

	@relay_root {
		header_regexp Host relay
		not path /health /status
	}
	handle @relay_root {
		header Content-Type "application/json"
		respond `{"service":"macula-relay"}` 200
	}

	handle {
		reverse_proxy central:4001
	}
}

# Bare domain — macula.io
macula.io {
	tls {
		dns linode {env.LINODE_DNS_API_TOKEN}
		key_type rsa2048
	}

	# Hecate installer proxy
	handle_path /hecate/* {
		rewrite * /hecate-social/hecate-node/main{uri}
		reverse_proxy https://raw.githubusercontent.com {
			header_up Host raw.githubusercontent.com
		}
	}

	reverse_proxy realm:4000
}

# On-demand TLS — custom franchise domains (e.g. beluxcloud.io)
:443 {
	tls {
		on_demand
	}
	reverse_proxy central:4001
}
