{
	on_demand_tls {
		ask http://central:4001/api/v1/internal/check-domain
	}
}

# Auctions subdomain
auctions.macula.io {
	tls {
		dns linode {env.LINODE_DNS_API_TOKEN}
		key_type rsa2048
	}
	reverse_proxy central:4001
}

# Relay status endpoints (must be before *.macula.io wildcard)
relay02.macula.io {
	tls {
		dns linode {env.LINODE_DNS_API_TOKEN}
		key_type rsa2048
	}
	handle /health {
		reverse_proxy relay02:9090
	}
	handle /status {
		reverse_proxy relay02:9090
	}
	handle {
		header Content-Type "application/json"
		respond `{"service":"macula-relay","endpoint":"quic://relay02.macula.io:4433"}` 200
	}
}

