# Macula Realm Production - Environment Configuration
# Copy to .env and fill in values. NEVER commit .env!

# =============================================================================
# Docker Image Versions
# =============================================================================
REALM_VERSION=latest
CENTRAL_VERSION=latest
AUCTIONS_VERSION=latest

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_USER=macula_realm
POSTGRES_PASSWORD=CHANGE_ME_USE_openssl_rand_base64_32
POSTGRES_DB=macula_realm_prod

# =============================================================================
# Phoenix Application
# =============================================================================
PHX_HOST=macula.io
# Generate with: mix phx.gen.secret
SECRET_KEY_BASE=CHANGE_ME_USE_mix_phx_gen_secret

# =============================================================================
# Erlang Clustering (auctions <-> central via pg)
# =============================================================================
# Generate with: openssl rand -base64 32
RELEASE_COOKIE=CHANGE_ME_USE_openssl_rand_base64_32

# =============================================================================
# GitHub OAuth (user authentication)
# =============================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# =============================================================================
# Caddy TLS (wildcard DNS-01 via Linode DNS API)
# =============================================================================
LINODE_DNS_API_TOKEN=

# =============================================================================
# Mailgun (contact form emails)
# =============================================================================
MACULA_MAILGUN_API_KEY=
MACULA_MAILGUN_DOMAIN=mg.macula.io
MACULA_MAILGUN_BASE_URL=https://api.eu.mailgun.net/v3
MACULA_CONTACT_EMAIL=contact@macula.io

# =============================================================================
# Admin Users
# =============================================================================
MACULA_ADMIN_GITHUB_USERNAMES=rgfaber

# =============================================================================
# GitHub App for GitOps (optional)
# =============================================================================
MACULA_GITOPS_GITHUB_APP_ID=
MACULA_GITOPS_GITHUB_APP_CLIENT_ID=
MACULA_GITOPS_GITHUB_APP_CLIENT_SECRET=
MACULA_GITOPS_GITHUB_APP_WEBHOOK_SECRET=
MACULA_GITOPS_GITHUB_APP_PRIVATE_KEY_PEM=
MACULA_GITOPS_GITHUB_APP_INSTALLATION_URL=https://github.com/apps/macula-gitops/installations/new

# =============================================================================
# Linode API Tokens (franchise VM provisioning)
# =============================================================================
LINODE_MACULA_IO_TOKEN=
LINODE_MACULA_IO_DNS_ONLY_TOKEN=

# =============================================================================
# GitHub Container Registry (private images)
# =============================================================================
GITHUB_USER=
GITHUB_MACULA_REALM_REGISTRY_PAT=

# =============================================================================
# Relay (multi-tenant, shares Caddy wildcard cert)
# =============================================================================
RELAY_VERSION=main
RELAY_HOSTNAME=relay02
MACULA_REALM=io.macula
MACULA_RELAYS=https://relay-de-nuremberg.macula.io:4433,https://relay-fi-helsinki.macula.io:4433,https://relay-fr-paris.macula.io:4433
MACULA_RELAY_IDENTITIES=relay-fr-paris.macula.io:Paris:FR:48.8566:2.3522,relay-uk-london.macula.io:London:UK:51.5074:-0.1278
MACULA_GEO_CITY=Paris
MACULA_GEO_COUNTRY=FR
MACULA_GEO_LAT=48.8566
MACULA_GEO_LNG=2.3522

# =============================================================================
# System
# =============================================================================
TZ=UTC
