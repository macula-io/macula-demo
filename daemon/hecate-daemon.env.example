# Hecate Daemon Configuration (headless node)
#
# This file is mounted into the container as env_file.
# Copy to hecate-daemon.env and edit for your node.

# Mesh
MACULA_RELAYS=https://relay00.macula.io:4433,https://relay01.macula.io:4433,https://relay02.macula.io:4433
HECATE_MESH_REALM=io.macula

# API socket
HECATE_SOCKET_PATH=/fast/.hecate/hecate-daemon/sockets/api.sock

# LLM
HECATE_LLM_BACKEND=ollama
HECATE_LLM_ENDPOINT=http://localhost:11434

# Hardware (adjust per node)
HECATE_RAM_GB=16
HECATE_CPU_CORES=4
HECATE_GPU=none

# BEAM Cluster
HECATE_NODE_NAME=hecate@beam00.lab
HECATE_ERLANG_COOKIE=ZMFTAHTHAYKXRVMPPQIZ
HECATE_CLUSTER_PEERS=host00.lab

# Data directory (must match HECATE_HOME in .env)
HECATE_HOME=/fast/.hecate
