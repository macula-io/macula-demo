# Relay identity (e.g., relay00, relay01, relay03)
RELAY_HOSTNAME=relay03

# Realm
MACULA_REALM=io.macula

# Image version (tag from ghcr.io/macula-io/macula-relay)
RELAY_VERSION=main

# Linode DNS API token (for Caddy TLS cert via DNS-01 challenge)
LINODE_DNS_API_TOKEN=your-linode-dns-api-token-here

# Peer relays (comma-separated, including self is fine — relay skips itself)
MACULA_RELAYS=https://relay00.macula.io:4433,https://relay01.macula.io:4433,https://relay02.macula.io:4433

# Admin API bearer token (for /admin/* endpoints)
MACULA_ADMIN_TOKEN=

# Multi-tenant virtual relay identities (hostname:city:country:lat:lng,...)
MACULA_RELAY_IDENTITIES=
