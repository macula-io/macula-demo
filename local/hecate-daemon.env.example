# Hecate Daemon Configuration (local attended node)
#
# Copy to hecate-daemon.env and edit.

# Mesh
MACULA_RELAYS=https://relay00.macula.io:4433,https://relay01.macula.io:4433,https://relay02.macula.io:4433
HECATE_MESH_REALM=io.macula

# API socket (hecate-web connects here)
HECATE_SOCKET_PATH=${HOME}/.hecate/hecate-daemon/sockets/api.sock

# LLM
HECATE_LLM_BACKEND=ollama
HECATE_LLM_ENDPOINT=http://localhost:11434

# Hardware (adjust for your machine)
HECATE_RAM_GB=32
HECATE_CPU_CORES=8
HECATE_GPU=none

# Node identity (standalone — no cluster)
HECATE_NODE_NAME=hecate_dev@localhost
HECATE_ERLANG_COOKIE=hecate-local-dev

# Data directory
HECATE_HOME=${HOME}/.hecate
